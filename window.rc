IDD_ACTIONPARAM DIALOG 0, 0, 220, 80
STYLE DS_ABSALIGN | DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Advanced Action" // Advanced Action
FONT 8, "Ms Shell Dlg"
BEGIN
    LTEXT "&Action:",IDC_ACTIONT,    5,  8, 50,  8
    COMBOBOX        IDC_ACTIONP0,    5, 18, 100, 160, MY_CBS_STYLE
    COMBOBOX        IDC_ACTIONP1,  110, 18, 50, 160, MY_CBS_STYLE
    EDITTEXT        IDC_ACTIONP2,  165, 18, 50,  12,  ES_AUTOHSCROLL
    LTEXT       "", IDC_ACTIONTSTRING,    8, 45, 100,  8
    
    DEFPUSHBUTTON   "OK",  IDOK, 108,60,50,14
    PUSHBUTTON   "Cancel", IDCANCEL, 165,60,50,14
END


